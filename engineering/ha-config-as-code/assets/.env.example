# Home Assistant Configuration as Code — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ─── Core Connection ──────────────────────────────────────────────────────────

# Internal HA URL (used as fallback)
HA_URL=http://192.168.1.100:8123

# External/HTTPS URL (used first if set; leave blank for local-only access)
HA_EXTERNAL_URL=https://your-domain.com:8123

# Long-lived access token from HA Profile → Long-Lived Access Tokens
HA_TOKEN=your_long_lived_access_token_here

# ─── SSH Access (only needed for setup_weather_forecast.py) ──────────────────

# IP or hostname of the HA host machine
HA_SSH_HOST=192.168.1.100

# SSH user (usually 'hassio' for HA OS or 'root' for supervised)
HA_SSH_USER=hassio

# SSH password (or leave blank if using key-based auth)
HA_SSH_PASSWORD=your_ssh_password_here
