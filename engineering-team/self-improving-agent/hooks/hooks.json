{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=$(find \"${HOME}/.claude/plugins\" -path \"*/self-improving-agent/*/hooks/error-capture.sh\" 2>/dev/null | sort -V | tail -1); [ -n \"$f\" ] && bash \"$f\"'"
          }
        ]
      }
    ]
  }
}
